{
    "actorSpecification": 1,
    "name": "contact-scraper",
    "title": "Contact Info Scraper",
    "description": "Scrapes emails, phone numbers, and social media links from company websites.",
    "version": "1.0",
    "buildTag": "latest",
    "input": "./input_schema.json",
    "storages": {
        "dataset": {
            "actorSpecification": 1,
            "title": "Contact Results",
            "views": {
                "overview": {
                    "title": "Overview",
                    "transformation": {
                        "fields": ["domain", "url", "emails", "phones", "linkedin", "facebook", "instagram", "twitter", "youtube"]
                    },
                    "display": {
                        "component": "table",
                        "properties": {
                            "domain": { "label": "Domain", "format": "text" },
                            "url": { "label": "URL", "format": "link" },
                            "emails": { "label": "Emails", "format": "array" },
                            "phones": { "label": "Phones", "format": "array" }
                        }
                    }
                }
            }
        }
    }
}
